# API host and port
HOST=127.0.0.1
PORT=8000

# Optional CORS list (comma-separated)
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Path to your notebook (default points to project root)
NOTEBOOK_PATH=code.ipynb

# Path to exported bundle folder from notebook
RECOMMENDER_BUNDLE_DIR=recommender_bundle/recommender_bundle

# Number of recommendations returned per request
RECOMMENDER_TOP_K=80

# Number of papers loaded from papers.json for searchable/queryable metadata
SEARCH_PAPER_LIMIT=10000

# Optional default user history seed indices
DEFAULT_USER_HISTORY=1,10,25,40

# Optional default user history using canonical paper IDs (preferred over indices)
DEFAULT_USER_HISTORY_IDS=
